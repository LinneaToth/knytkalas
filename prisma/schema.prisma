// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id                String         @id @default(cuid())
  createdAt         DateTime    @default(now())
  email             String      @unique
  name              String?
  sentInvites       Invite[]    @relation("SentInvite")
  receivedInvites   Invite[]    @relation("ReceivedInvite")
  hostedEvents      Event[]     @relation("HostedEvents")
  avoids            IssueType[] 
  }

enum IssueType {
  MEAT 
  DAIRY 
  LACTOSE
  NUTS
  GLUTEN
  EGG
  SHELLFISH
  FISH
  ANIMALBASED
}

enum RsvpStatus { 
  PENDING 
  GOING 
  DECLINED 
  }

  enum CategoryType {
  STARTER    
  MAIN   
  SALAD    
  SIDE
  BREAD 
  DESSERT 
  SNACK 
  DRINK 
  OTHER 
}

model Contribution {
  id        Int     @id @default(autoincrement())
  invite    Invite  @relation(fields: [inviteId], references: [id])
  inviteId  Int
  name      String
  servings  Int?
  category  CategoryType
  contains  IssueType[]
}

model Invite {
  id            Int             @id @default(autoincrement())
  createdAt     DateTime        @default(now())
  token         String          @unique @default(cuid())
  event         Event           @relation(fields: [eventId], references: [id])
  eventId       Int
  invBy         User            @relation("SentInvite", fields: [invById], references: [id])
  invById       String
  guest         User?            @relation("ReceivedInvite", fields: [guestId], references: [id])
  guestId       String?
  contributions Contribution[]  
  status        RsvpStatus      @default(PENDING)
}

model Event {
  id                Int         @id @default(autoincrement())
  createdAt         DateTime    @default(now())
  occasion          String
  description       String?
  invites           Invite[]
  activeCategories  CategoryType[]   
  date              DateTime
  location          String?
  responseDeadline  DateTime?
  host              User   @relation("HostedEvents", fields: [hostId], references: [id])
  hostId            String
}